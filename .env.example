# DROPBOX MUSIC PLAYER - Environment Configuration
# Copy this to .env and fill in your actual values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/dropbox-music
# OR for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dropbox-music

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Server Port
PORT=5000
NODE_ENV=development

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=dropbox-music-bucket
AWS_REGION=us-east-1

# Email Configuration (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Payment Gateway (Stripe/PayPal)
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5000
# For Render deployment, set this to your Render service URL:
# FRONTEND_URL=https://your-app-name.onrender.com

# File Upload
MAX_FILE_SIZE=52428800 # 50MB in bytes
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,m4a,aac

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE=+1234567890

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379
