# DROPBOX MUSIC PLAYER - Production Environment Configuration
# Update these values for production deployment

# MongoDB Connection (Use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dropbox-music?retryWrites=true&w=majority

# JWT Secret (Generate a strong random secret for production)
JWT_SECRET=dropbox-music-production-secret-key-change-this-to-a-very-long-random-string

# Server Port
PORT=5000
NODE_ENV=production

# AWS S3 Configuration (Required for file uploads in production)
AWS_ACCESS_KEY_ID=your-production-aws-access-key
AWS_SECRET_ACCESS_KEY=your-production-aws-secret-key
AWS_S3_BUCKET=dropbox-music-production-bucket
AWS_REGION=us-east-1

# Email Configuration (For notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-production-email@gmail.com
EMAIL_PASSWORD=your-production-app-password

# Frontend URL (For CORS in production)
FRONTEND_URL=https://yourdomain.com

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,m4a,aac

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (Optional for caching)
REDIS_URL=redis://localhost:6379

# Email Configuration (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Payment Gateway (Stripe/PayPal)
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5000

# File Upload
MAX_FILE_SIZE=52428800 # 50MB in bytes
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,m4a,aac

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE=+1234567890

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379
